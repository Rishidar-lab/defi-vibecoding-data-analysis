# Environment variables for defi-vibecoding-data-analysis
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Optional: DefiLlama API base URL (defaults to public endpoint, no auth required)
# DEFILLAMA_API_BASE=https://yields.llama.fi

# Optional: Minimum pool TVL filter in USD (default: 5000000)
# MIN_TVL_USD=5000000

# Optional: Chain TVL momentum de-risk threshold (default: -0.15 = -15%)
# DE_RISK_THRESHOLD=-0.15

# Optional: Maximum allocation per pool (default: 0.40 = 40%)
# MAX_POOL_WEIGHT=0.40

# Optional: Rebalance interval in days (default: 14)
# REBALANCE_INTERVAL_DAYS=14
